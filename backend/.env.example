# ============================================================
# CYH Mapping Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------
# PostgreSQL connection string
# Local example:   postgresql://localhost:5432/cyh_mapping
# With auth:       postgresql://cyh_app:yourpassword@localhost:5432/cyh_mapping
# AWS RDS example: postgresql://cyh_app:yourpassword@mydb.abcdef.us-west-2.rds.amazonaws.com:5432/cyh_mapping
DATABASE_URL=postgresql://localhost:5432/cyh_mapping

# Set to "true" if your database requires SSL (e.g., AWS RDS).
# Leave empty or "false" for local development.
DB_SSL=false

# ------------------------------------------------------------
# Server (required)
# ------------------------------------------------------------
# Port the Express server listens on
PORT=5050

# Secret string for signing session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# ------------------------------------------------------------
# Admin (required)
# ------------------------------------------------------------
# Email address of the site owner/primary admin.
# Used for "contact support" messages in the admin panel.
OWNER_EMAIL=admin@example.com

# ------------------------------------------------------------
# URLs (required)
# ------------------------------------------------------------
# Public URL of the frontend (used to generate preview links in admin panel)
FRONTEND_URL=http://localhost:3000

# Public URL of this backend server
BACKEND_URL=http://localhost:5050

# Base URL for auth links (password reset, etc.). Usually same as BACKEND_URL with trailing slash.
SERVER_URL=http://localhost:5050/

# ------------------------------------------------------------
# Google Maps Geocoding (optional)
# ------------------------------------------------------------
# API key for resolving addresses to lat/lon coordinates.
# Get one at: https://console.cloud.google.com/apis/credentials
# If blank, geocoding features will not work (addresses won't get map pins).
GOOGLE_API_KEY=

# ------------------------------------------------------------
# OpenAI — Chat (optional)
# ------------------------------------------------------------
# API key for the AI chat feature. Get one at https://platform.openai.com/api-keys
# If blank, the chat will return an error when users send messages.
OPENAI_API_KEY=

# ------------------------------------------------------------
# Email — AWS SES (production)
# ------------------------------------------------------------
# Email is sent via Amazon SES. On EC2, the instance IAM role provides
# credentials automatically. Ensure mail@casperyouthhubmap.org and
# OWNER_EMAIL are verified in SES (us-west-2). No API key needed.
# For local dev, set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY if needed.
# AWS_REGION=us-west-2

# ------------------------------------------------------------
# Airtable (optional, legacy)
# ------------------------------------------------------------
# These are from the original project's Airtable integration.
# Not required unless you're using Airtable as a data source.
AIRTABLE_API_KEY=
BASE_ID=
