<div class="ui segment" style="max-width: 800px; margin: 2em auto; padding: 2em;">
  <header style="text-align: center; margin-bottom: 1.5em;">
    <h1 class="ui header dark-teal-text">
      <i class="ui icon edit"></i>
      <div class="content">
        Edit Listing
        <div class="sub header">#<%= props.listing.guid %> &mdash; <%= props.listing.full_name %></div>
      </div>
    </h1>
  </header>

  <% if (props.success) { %>
  <div class="ui success icon message">
    <i class="large check middle aligned icon"></i>
    <div class="content">
      <div class="header">Listing Updated</div>
      <p>"<%= props.listing.full_name %>" has been saved.</p>
    </div>
  </div>
  <% } %>

  <% if (props.error) { %>
  <div class="ui negative message">
    <div class="header">Error</div>
    <p><%= props.error %></p>
  </div>
  <% } %>

  <% var l = props.listing; %>
  <% var selectedCategories = (Array.isArray(l.category) ? l.category : String(l.category || '').split(/\s*(?:\|\||;|\n)\s*/)).map(function(c){ return c.trim(); }).filter(Boolean); %>

    <form class="ui form" action="/listings/edit/<%= l.guid %>" method="POST" enctype="multipart/form-data">

    <h3 class="ui dividing header">Required</h3>

    <div class="required field">
      <label>Resource Name</label>
      <input type="text" name="full_name" value="<%= l.full_name || '' %>" required>
    </div>

    <div class="required field">
      <label>Categories</label>
      <select name="category" multiple required style="width:100%; min-height:160px; padding:.67em 1em; border:1px solid rgba(34,36,38,.15); border-radius:.29em; font-size:1em;">
        <% if (props.categories) { %>
          <% props.categories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= selectedCategories.includes(cat) ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        <% } %>
      </select>
      <small style="color:#888;">Hold Cmd/Ctrl to select multiple categories.</small>
    </div>

    <div class="field">
      <label>Additional Categories (optional)</label>
      <textarea name="custom_categories" rows="2" placeholder="Use semicolons or new lines. Example: Education &amp; Workforce: GED Prep; Basic Needs: Food"></textarea>
    </div>
    <div class="field">
      <label>Selected Categories Preview</label>
      <div id="category-preview" style="min-height: 2.5em;"></div>
      <small style="color:#888;">This listing will appear in each category shown here.</small>
    </div>

    <div class="required field">
      <label>Description</label>
      <div style="display: flex; gap: .5em; align-items: flex-start;">
        <textarea name="description" id="description-field" rows="3" placeholder="Describe the program or services your organization provides" required><%= l.description || '' %></textarea>
        <button type="button" id="suggest-tags-btn" class="ui button basic teal" title="Use AI to suggest Service Type and tags from the description">
          <i class="magic icon"></i> Suggest tags
        </button>
      </div>
      <small id="suggest-tags-status" style="color:#888; display:none;"></small>
    </div>

    <h3 class="ui dividing header">Point Person (Internal Only)</h3>

    <div class="three fields">
      <div class="field">
        <label>Contact Name</label>
        <input type="text" name="contact_name" value="<%= l.contact_name || '' %>">
      </div>
      <div class="field">
        <label>Contact Email</label>
        <input type="email" name="contact_email" value="<%= l.contact_email || '' %>">
      </div>
      <div class="field">
        <label>Contact Phone</label>
        <input type="text" name="contact_phone" value="<%= l.contact_phone || '' %>">
      </div>
    </div>

    <h3 class="ui dividing header">Contact Info</h3>

    <div class="two fields">
      <div class="field">
        <label>Phone</label>
        <input type="text" name="phone_1" value="<%= l.phone_1 || '' %>">
      </div>
      <div class="field">
        <label>Crisis Line</label>
        <input type="text" name="crisis_line_number" value="<%= l.crisis_line_number || '' %>">
      </div>
    </div>

    <div class="two fields">
      <div class="field">
        <label>Website</label>
        <input type="url" name="website" value="<%= l.website || '' %>">
      </div>
      <div class="field">
        <label>Email</label>
        <input type="email" name="program_email" value="<%= l.program_email || '' %>">
      </div>
    </div>

    <h3 class="ui dividing header">Location</h3>

    <div class="field">
      <label>Organization / Location Name</label>
      <input type="text" name="parent_organization" value="<%= l.parent_organization || '' %>">
    </div>

    <div class="field">
      <label>Full Address</label>
      <input type="text" name="full_address" value="<%= l.full_address || '' %>">
      <% if (l.latitude && l.longitude) { %>
        <small style="color: #888;">Current coords: (<%= l.latitude %>, <%= l.longitude %>)</small>
      <% } else { %>
        <small style="color: #c0392b;">No map coordinates — will auto-geocode on save if address is provided</small>
      <% } %>
    </div>

    <div class="two fields">
      <div class="field">
        <label>City</label>
        <input type="text" name="city" value="<%= l.city || '' %>">
      </div>
      <div class="field">
        <label>Service Type</label>
        <% 
          var delivery = [];
          if (Array.isArray(l.service_delivery)) { delivery = l.service_delivery; }
          else if (typeof l.service_delivery === 'string' && l.service_delivery) { try { delivery = JSON.parse(l.service_delivery); } catch(e) {} }
          var kw = Array.isArray(l.keywords) ? l.keywords.join(',') : (l.keywords || '');
          var hasInPerson = delivery.includes('In-Person') || kw.includes('In-Person');
          var hasOnline = delivery.includes('Online') || kw.includes('Online Only');
          var hasTelehealth = delivery.includes('Telehealth') || kw.includes('Telehealth');
        %>
        <select class="ui dropdown" name="service_type">
          <option value="In-Person" <%= hasInPerson && !hasTelehealth ? 'selected' : '' %>>In-Person</option>
          <option value="Online Only" <%= hasOnline && !hasInPerson && !hasTelehealth ? 'selected' : '' %>>Online Only</option>
          <option value="In-Person,Telehealth" <%= hasInPerson && hasTelehealth ? 'selected' : '' %>>In-Person + Telehealth</option>
          <option value="Telehealth" <%= hasTelehealth && !hasInPerson ? 'selected' : '' %>>Telehealth Only</option>
        </select>
      </div>
    </div>

    <div class="two fields">
      <div class="field">
        <label>Age Group Served</label>
        <select class="ui dropdown" name="age_group">
          <option value="Youth and Adult" <%= (l.age_group || 'Youth and Adult') === 'Youth and Adult' ? 'selected' : '' %>>Youth and Adult</option>
          <option value="Youth" <%= l.age_group === 'Youth' ? 'selected' : '' %>>Youth Only</option>
          <option value="Adult" <%= l.age_group === 'Adult' ? 'selected' : '' %>>Adult Only</option>
        </select>
      </div>
      <div class="field" style="display: flex; align-items: flex-end; padding-bottom: .5em;">
        <div class="ui checkbox">
          <input type="checkbox" name="faith_based" id="faith_based_edit" <%= kw.includes('Faith-Based') ? 'checked' : '' %>>
          <label for="faith_based_edit"><i class="church icon"></i> Faith-Based Organization</label>
        </div>
      </div>
    </div>

    <div class="field">
      <div class="ui checkbox">
        <input type="checkbox" name="re_geocode" id="re_geocode">
        <label for="re_geocode">Re-geocode address (check this if you changed the address)</label>
      </div>
    </div>

    <h3 class="ui dividing header">Building Photo</h3>

    <div class="field">
      <% if (l.image_url) { %>
        <div style="margin-bottom: .75em;">
          <img src="<%= l.image_url %>" alt="Building photo" style="max-width: 300px; max-height: 200px; border-radius: 6px; border: 1px solid #ddd;">
        </div>
        <div class="ui checkbox" style="margin-bottom: .5em;">
          <input type="checkbox" name="remove_image" id="remove_image">
          <label for="remove_image">Remove current photo</label>
        </div>
      <% } %>
      <label><i class="camera icon"></i> <%= l.image_url ? 'Replace' : 'Upload' %> building photo</label>
      <input type="file" name="building_image" accept="image/jpeg,image/png,image/webp">
      <small style="color: #888;">Helps youth recognize where they're going. Max 5 MB. JPG, PNG, or WebP.</small>
    </div>

    <h3 class="ui dividing header">Inside the Building (Multi-Office Buildings)</h3>
    <p class="ui message" style="font-size: 0.9em;">For offices inside a building with multiple other offices: add a photo of your office entrance and directions so youth know they're in the right place.</p>
    <div class="field">
      <label>Directions once inside the building</label>
      <textarea name="internal_directions" rows="3" placeholder="e.g. Take the elevator to the 2nd floor, turn left, we're the third door on the right"><%= l.internal_directions || '' %></textarea>
    </div>
    <div class="field">
      <% if (l.office_entrance_image_url) { %>
        <div style="margin-bottom: .75em;">
          <img src="<%= l.office_entrance_image_url %>" alt="Office entrance" style="max-width: 300px; max-height: 200px; border-radius: 6px; border: 1px solid #ddd;">
        </div>
        <div class="ui checkbox" style="margin-bottom: .5em;">
          <input type="checkbox" name="remove_office_entrance_image" id="remove_office_entrance_image">
          <label for="remove_office_entrance_image">Remove office entrance photo</label>
        </div>
      <% } %>
      <label><i class="door open icon"></i> <%= l.office_entrance_image_url ? 'Replace' : 'Upload' %> photo of office entrance (from inside)</label>
      <input type="file" name="office_entrance_image" accept="image/jpeg,image/png,image/webp">
      <small style="color: #888;">Photo of your office door/entrance so youth know they're in the right place. Max 5 MB.</small>
    </div>

    <h3 class="ui dividing header">Details</h3>

    <div class="two fields">
      <div class="field">
        <label>Min Age</label>
        <input type="number" name="min_age" value="<%= l.min_age || '' %>" min="0" max="99">
      </div>
      <div class="field">
        <label>Max Age</label>
        <input type="number" name="max_age" value="<%= l.max_age || '' %>" min="0" max="99">
      </div>
    </div>

    <div class="field">
      <label>Eligibility Requirements</label>
      <input type="text" name="eligibility_requirements" value="<%= l.eligibility_requirements || '' %>">
    </div>

    <div class="field">
      <label>Cost / Financial Info</label>
      <input type="text" name="financial_information" value="<%= l.financial_information || '' %>">
    </div>

    <div class="field">
      <label>Languages Offered (comma separated)</label>
      <input type="text" name="languages_offered" value="<%= Array.isArray(l.languages_offered) ? l.languages_offered.join(', ') : (l.languages_offered || '') %>">
    </div>

    <div class="field">
      <label>Next Steps / Intake Instructions</label>
      <textarea name="intake_instructions" rows="2"><%= l.intake_instructions || '' %></textarea>
    </div>

    <div class="ui divider"></div>

    <div style="display: flex; gap: .5em;">
      <button type="submit" class="ui button teal-background" style="flex:1; font-size: 1.1em;">
        <i class="save icon"></i> Save Changes
      </button>
      <a href="/listings/manage" class="ui button basic" style="font-size: 1.1em;">Cancel</a>
    </div>
  </form>
</div>

<script>
  (function initCategoryPreview() {
    const categorySelect = document.querySelector('select[name="category"]');
    const customCategoriesInput = document.querySelector('textarea[name="custom_categories"]');
    const preview = document.getElementById('category-preview');
    if (!categorySelect || !preview) return;

    const parseCustomCategories = (value) =>
      (value || '')
        .split(/[\n;]+/)
        .map((entry) => entry.trim())
        .filter(Boolean);

    const renderPreview = () => {
      const selected = Array.from(categorySelect.selectedOptions).map((option) => option.value).filter(Boolean);
      const custom = parseCustomCategories(customCategoriesInput ? customCategoriesInput.value : '');
      const merged = Array.from(new Set([...selected, ...custom]));

      preview.innerHTML = '';
      if (merged.length === 0) {
        const emptyState = document.createElement('span');
        emptyState.style.color = '#888';
        emptyState.textContent = 'No categories selected yet.';
        preview.appendChild(emptyState);
        return;
      }

      merged.forEach((category) => {
        const label = document.createElement('span');
        label.className = 'ui label';
        label.style.margin = '0 0.4em 0.4em 0';
        label.textContent = category;
        preview.appendChild(label);
      });
    };

    categorySelect.addEventListener('change', renderPreview);
    if (customCategoriesInput) customCategoriesInput.addEventListener('input', renderPreview);
    renderPreview();
  })();

  (function initSuggestTags() {
    const btn = document.getElementById('suggest-tags-btn');
    const descField = document.getElementById('description-field');
    const statusEl = document.getElementById('suggest-tags-status');
    const serviceTypeSelect = document.querySelector('select[name="service_type"]');
    const faithBasedCheckbox = document.getElementById('faith_based_edit');
    if (!btn || !descField) return;

    btn.addEventListener('click', async function() {
      const desc = (descField.value || '').trim();
      if (!desc) {
        statusEl.textContent = 'Enter a description first.';
        statusEl.style.display = 'block';
        statusEl.style.color = '#c0392b';
        return;
      }
      btn.disabled = true;
      statusEl.textContent = 'Analyzing...';
      statusEl.style.display = 'block';
      statusEl.style.color = '#888';
      try {
        const res = await fetch('/listings/suggest-tags', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ description: desc }),
          credentials: 'same-origin'
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Request failed');

        var serviceTypeVal = 'In-Person';
        if (data.service_delivery && data.service_delivery.length) {
          var sd = data.service_delivery;
          if (sd.includes('Online') && !sd.includes('In-Person') && !sd.includes('Telehealth')) serviceTypeVal = 'Online Only';
          else if (sd.includes('Telehealth') && !sd.includes('In-Person')) serviceTypeVal = 'Telehealth';
          else if (sd.includes('In-Person') && sd.includes('Telehealth')) serviceTypeVal = 'In-Person,Telehealth';
          else if (sd.includes('In-Person')) serviceTypeVal = 'In-Person';
        }
        if (serviceTypeSelect) {
          serviceTypeSelect.value = serviceTypeVal;
        }
        if (faithBasedCheckbox && data.keywords && data.keywords.includes('Faith-Based')) {
          faithBasedCheckbox.checked = true;
        }
        var extra = [];
        if (data.insurance_keywords && data.insurance_keywords.length) extra.push('Insurance: ' + data.insurance_keywords.join(', '));
        if (data.keywords && data.keywords.length) {
          var other = data.keywords.filter(function(k) { return k !== 'Faith-Based'; });
          if (other.length) extra.push('Other: ' + other.join(', '));
        }
        statusEl.textContent = 'Tags applied.' + (extra.length ? ' ' + extra.join(' | ') : '');
        statusEl.style.color = '#16a085';
      } catch (e) {
        statusEl.textContent = 'Error: ' + (e.message || 'Could not suggest tags');
        statusEl.style.color = '#c0392b';
      }
      btn.disabled = false;
    });
  })();
</script>
