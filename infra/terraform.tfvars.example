# ============================================================
# CYH Mapping — Terraform Variables
# ============================================================
# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control.
# ============================================================

# AWS region to deploy into
aws_region = "us-west-2"

# Project name (used for naming all AWS resources)
project_name = "cyh-mapping"

# EC2 instance type (t4g.micro is free-tier eligible for 12 months)
instance_type = "t4g.micro"

# Name of an existing AWS key pair for SSH access
# Create one in AWS Console: EC2 > Key Pairs > Create key pair
ssh_key_name = "my-key-pair"

# PostgreSQL database password
db_password = "change-me-to-a-strong-password"

# Initial admin user for the backend admin panel
admin_email    = "admin@example.com"
admin_password = "change-me-to-a-strong-password"

# Express session signing secret (random string, at least 32 characters)
session_secret = "generate-a-random-string-here"

# Google Maps Geocoding API key (optional — leave empty to skip geocoding)
# Get one at: https://console.cloud.google.com/apis/credentials
google_api_key = ""

# OpenAI API key for chat feature (optional — leave empty to disable chat)
# Get one at: https://platform.openai.com/api-keys
openai_api_key = ""

# Primary custom domain (e.g. casperyouthhubmap.org)
# Leave empty to use the CloudFront default URL.
domain_name = "casperyouthhubmap.org"

# Additional domains that serve the same site (no redirect — visitors stay on whichever URL they used)
# For each domain, update its registrar to use the nameservers from `terraform output route53_nameservers_additional`
additional_domain_names = ["wyomingyouthresourcemap.com"]

# RDS instance class (db.t4g.micro is the smallest/cheapest option)
db_instance_class = "db.t4g.micro"

# GitHub repo URL for the backend code (cloned onto EC2 during bootstrap)
github_repo_url = "https://github.com/cajun1689/cyh-mapping.git"

# CIDR blocks allowed to SSH into the EC2 instance
# For better security, replace with your IP: ["1.2.3.4/32"]
allowed_ssh_cidrs = ["0.0.0.0/0"]
